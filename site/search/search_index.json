{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Home","text":""},{"location":"#pin","title":"Pin\u597d\u56fe","text":"<p>\u4e22\u56fe\u4e0a\u53bb\uff0c\u81ea\u52a8\u5728 Pinterest \u7f51\u9875\u91cc\u641c\u76f8\u4f3c\u56fe\u3002</p> <p>\u4e0b\u8f7d\u63d2\u4ef6</p>"},{"location":"#_1","title":"\u5feb\u901f\u5f00\u59cb","text":"<p>1. \u6309\u300c\u5b89\u88c5\u6559\u7a0b\u300d\u52a0\u8f7d\u6269\u5c55\uff08\u5f00\u53d1\u8005\u6a21\u5f0f\uff09</p> <p>2. \u7533\u8bf7\u5e76\u4fdd\u5b58 Gemini API key</p> <p>3. \u4e0a\u4f20\u53c2\u8003\u56fe\uff0c\u4e00\u952e\u8df3\u8f6c Pinterest \u641c\u7d22\u7ed3\u679c</p> \u5b89\u88c5\u6559\u7a0b \u4f7f\u7528\u6559\u7a0b"},{"location":"#_2","title":"\u7248\u672c","text":"<p>\u6b63\u5728\u52a0\u8f7d\u7248\u672c\u4fe1\u606f\u2026</p> <p></p>"},{"location":"download/","title":"\u4e0b\u8f7d\u63d2\u4ef6","text":"\u4e0b\u8f7d\u63d2\u4ef6"},{"location":"download/#_1","title":"\u83b7\u53d6\u65b9\u5f0f","text":"<ul> <li>\u82e5\u5df2\u6709\u53d1\u5e03\u5305\uff08\u5982 PinHaotu-v1.x.x-\u53d1\u5e03\u5305.zip\uff09\uff0c\u89e3\u538b\u540e\u5176\u4e2d\u7684 Extension \u6587\u4ef6\u5939\u5373\u4e3a\u63d2\u4ef6\u76ee\u5f55\u3002</li> <li>\u6216\u4ece GitHub Releases \u9875\u9762\u4e0b\u8f7d\u6700\u65b0\u53d1\u5e03\u5305\uff0c\u89e3\u538b\u540e\u4f7f\u7528\u5176\u4e2d\u7684 Extension \u6587\u4ef6\u5939\u3002</li> </ul> <p>\u4e0b\u8f7d\u5e76\u89e3\u538b\u540e\uff0c\u8bf7\u7ee7\u7eed\u9605\u8bfb \u5b89\u88c5\u6559\u7a0b \u5b8c\u6210\u52a0\u8f7d\u3002</p>"},{"location":"install/","title":"\u5b89\u88c5\u6559\u7a0b","text":"\u3010\u91cd\u8981\u3011 \u4f7f\u7528\u672c\u63d2\u4ef6\u65f6\u8bf7\u786e\u4fdd\u5728\u79d1\u5b66\u4e0a\u7f51\uff08\u6302 VPN\uff09\u73af\u5883\u4e0b\uff0c\u80fd\u6b63\u5e38\u6d4f\u89c8 Pinterest \u7f51\u7ad9\u5373\u53ef\u6b63\u5e38\u4f7f\u7528\u3002"},{"location":"install/#_2","title":"\u4e00\u3001\u73af\u5883\u8981\u6c42","text":"<ul> <li>\u4f7f\u7528 Chromium \u5185\u6838\u7684\u6d4f\u89c8\u5668\uff08\u5982 Google Chrome\u3001Microsoft Edge\u3001Brave \u7b49\uff09</li> <li>\u5df2\u5b89\u88c5\u5e76\u53ef\u6b63\u5e38\u8bbf\u95ee Pinterest \u7f51\u7ad9\uff08\u9700\u79d1\u5b66\u4e0a\u7f51/\u6302 VPN \u65f6\u8bf7\u5148\u914d\u7f6e\u597d\uff09</li> </ul>"},{"location":"install/#_3","title":"\u4e8c\u3001\u5b89\u88c5\u6b65\u9aa4\uff08\u5f00\u53d1\u8005\u6a21\u5f0f\u52a0\u8f7d\uff09","text":"<ol> <li>\u89e3\u538b\u6216\u590d\u5236\u672c\u53d1\u5e03\u5305\u4e2d\u7684\u300cExtension\u300d\u6587\u4ef6\u5939\u5230\u4efb\u610f\u4f4d\u7f6e\uff08\u8def\u5f84\u4e2d\u5c3d\u91cf\u65e0\u4e2d\u6587\u3001\u65e0\u7a7a\u683c\uff09\u3002</li> <li>\u6253\u5f00\u6d4f\u89c8\u5668\uff0c\u5728\u5730\u5740\u680f\u8f93\u5165\u5e76\u56de\u8f66\uff1a  </li> <li>\u82e5\u662f\u7528 Chrome \u6d4f\u89c8\u5668\uff1a<code>chrome://extensions/</code> </li> <li>\u82e5\u662f\u7528 Edge \u6d4f\u89c8\u5668\uff1a<code>edge://extensions/</code></li> <li>\u6253\u5f00\u300c\u5f00\u53d1\u8005\u6a21\u5f0f\u300d\u5f00\u5173\u3002  </li> <li>Chrome\uff1a\u5728\u9875\u9762\u53f3\u4e0a\u89d2\u3002  </li> <li>Edge\uff1a\u5728\u9875\u9762\u5de6\u4fa7\u5e95\u90e8\u3002</li> <li>\u70b9\u51fb\u300c\u52a0\u8f7d\u5df2\u89e3\u538b\u7684\u6269\u5c55\u7a0b\u5e8f\u300d\uff08Chrome\uff09\u6216\u300c\u52a0\u8f7d\u89e3\u538b\u7f29\u7684\u6269\u5c55\u300d\uff08Edge\uff09\u3002</li> <li>\u5728\u5f39\u7a97\u4e2d\u9009\u4e2d\u521a\u624d\u7684\u300cExtension\u300d\u6587\u4ef6\u5939\uff0c\u76f4\u63a5\u70b9\u51fb\u300c\u9009\u62e9\u6587\u4ef6\u5939\u300d\u6216\u300c\u9009\u62e9\u300d\u5373\u53ef\u3002</li> <li>\u82e5\u672a\u62a5\u9519\uff0c\u6269\u5c55\u5217\u8868\u4e2d\u51fa\u73b0\u300cPin\u597d\u56fe\u300d\u5373\u5b89\u88c5\u6210\u529f\u3002\u53ef\u5c06\u6269\u5c55\u56fa\u5b9a\u5230\u5de5\u5177\u680f\u4ee5\u4fbf\u4f7f\u7528\u3002</li> </ol>"},{"location":"install/#_4","title":"\u66f4\u65b0\u5df2\u6709\u7248\u672c\uff08\u91cd\u8981\uff09","text":"<ol> <li>\u89e3\u538b\u65b0\u53d1\u5e03\u5305\uff0c\u7528\u5176\u4e2d\u7684\u300cExtension\u300d\u6587\u4ef6\u5939\u8986\u76d6\u539f\u5b89\u88c5\u4f4d\u7f6e\u4e0b\u7684\u540c\u540d\u6587\u4ef6\u5939\uff08\u6216\u5148\u5220\u9664\u65e7 Extension\uff0c\u518d\u653e\u5165\u65b0\u89e3\u538b\u7684 Extension \u5230\u540c\u4e00\u8def\u5f84\uff09\u3002</li> <li>\u6253\u5f00 <code>chrome://extensions/</code> \u6216 <code>edge://extensions/</code>\uff0c\u627e\u5230 Pin\u597d\u56fe\uff0c\u70b9\u51fb\u6269\u5c55\u5361\u7247\u4e0a\u7684\u300c\u5237\u65b0\u300d\u56fe\u6807\u5373\u53ef\u751f\u6548\u3002</li> </ol>   \u6309\u4e0a\u8ff0\u65b9\u5f0f\u66f4\u65b0\u65f6\uff0c\u5df2\u4fdd\u5b58\u7684 API key \u4f1a\u4fdd\u7559\uff0c\u65e0\u9700\u91cd\u65b0\u8f93\u5165\u3002  \u8bf7\u52ff\u5148\u79fb\u9664\u6269\u5c55\u518d\u91cd\u65b0\u52a0\u8f7d\u5176\u4ed6\u6587\u4ef6\u5939\uff0c\u5426\u5219\u4f1a\u89c6\u4e3a\u65b0\u6269\u5c55\uff0c\u5df2\u4fdd\u5b58\u7684\u5bc6\u94a5\u4e0e\u8bbe\u7f6e\u4f1a\u4e22\u5931\u3002"},{"location":"install/#_5","title":"\u4e09\u3001\u4fa7\u8fb9\u680f\u4f7f\u7528\u65b9\u5f0f\uff08\u63a8\u8350\uff09","text":"<ul> <li>\u5728\u6269\u5c55\u5217\u8868\u4e2d\u627e\u5230 Pin\u597d\u56fe\uff0c\u70b9\u51fb\u5176\u53f3\u4fa7\u7684\u300c\u4fa7\u8fb9\u680f\u300d\u56fe\u6807\uff0c\u6216</li> <li>\u5728 Pinterest \u9875\u9762\u6309\u9700\u6253\u5f00\u4fa7\u8fb9\u680f\u540e\u9009\u62e9 Pin\u597d\u56fe\u3002  </li> </ul> <p>\u4fa7\u8fb9\u680f\u4f1a\u5e38\u9a7b\u5728 Pinterest \u9875\u9762\u4e00\u4fa7\uff0c\u65e0\u9700\u6bcf\u6b21\u5f39\u7a97\u3002</p>"},{"location":"install/#_6","title":"\u56db\u3001\u9996\u6b21\u4f7f\u7528\u524d\u5fc5\u505a","text":"<ul> <li>\u5728\u63d2\u4ef6\u4e2d\u70b9\u51fb\u300cAPI key\u300d\u5c55\u5f00\uff0c\u70b9\u51fb\u300c\u7533\u8bf7\u5bc6\u94a5\u300d\u65c1\u7684 ? \u53ef\u67e5\u770b\u83b7\u53d6\u6559\u7a0b\u3002</li> <li>\u5728 Google AI Studio \u7533\u8bf7 Gemini API \u5bc6\u94a5\u540e\uff0c\u7c98\u8d34\u5230\u8f93\u5165\u6846\u5e76\u70b9\u51fb\u300c\u4fdd\u5b58\u300d\u3002</li> <li>\u5bc6\u94a5\u4ec5\u5b58\u4e8e\u672c\u673a\uff0c\u4e0d\u4f1a\u4e0a\u4f20\u3002</li> </ul>"},{"location":"install/#_7","title":"\u4e94\u3001\u82e5\u5b89\u88c5\u540e\u65e0\u6cd5\u4f7f\u7528","text":"<ul> <li>\u786e\u8ba4\u300c\u5f00\u53d1\u8005\u6a21\u5f0f\u300d\u5df2\u5f00\u542f\u4e14\u6269\u5c55\u5df2\u542f\u7528\u3002</li> <li>\u786e\u8ba4\u5728 Pinterest \u57df\u540d\u4e0b\u4f7f\u7528\uff08\u5982 https://www.pinterest.com/\uff09\u3002</li> <li>\u82e5\u63d0\u793a\u6743\u9650\u6216\u7f51\u7edc\u9519\u8bef\uff0c\u8bf7\u68c0\u67e5\u6d4f\u89c8\u5668\u662f\u5426\u5141\u8bb8\u6269\u5c55\u8bbf\u95ee\u76f8\u5e94\u7f51\u7ad9\u3002</li> </ul>"},{"location":"usage/","title":"\u4f7f\u7528\u6559\u7a0b","text":"\u3010\u91cd\u8981\u3011\u4f7f\u7528\u524d\u8bf7\u786e\u4fdd\u5728\u79d1\u5b66\u4e0a\u7f51\uff08\u6302 VPN\uff09\u73af\u5883\u4e0b\u4f7f\u7528\u672c\u63d2\u4ef6\uff0c\u80fd\u6b63\u5e38\u6d4f\u89c8 Pinterest \u7f51\u7ad9\u5373\u53ef\u6b63\u5e38\u4f7f\u7528\u672c\u63d2\u4ef6\u3002"},{"location":"usage/#_2","title":"\u4e00\u3001\u529f\u80fd\u7b80\u4ecb","text":"<p>Pin\u597d\u56fe\u901a\u8fc7 Gemini API \u8bc6\u522b\u4f60\u4e0a\u4f20\u7684\u53c2\u8003\u56fe\uff0c\u81ea\u52a8\u751f\u6210\u641c\u7d22\u5173\u952e\u8bcd\uff0c\u5e76\u5728 Pinterest \u4e0a\u641c\u7d22\u76f8\u4f3c\u56fe\u7247\uff0c\u9002\u5408\u627e\u53c2\u8003\u3001\u627e\u98ce\u683c\u3001\u627e\u914d\u8272\u3002</p>"},{"location":"usage/#api","title":"\u4e8c\u3001API \u5bc6\u94a5\u4e0e\u9690\u79c1\uff08\u9996\u6b21\u4f7f\u7528\u5fc5\u8bfb\uff09","text":"<ul> <li>\u9700\u5728 Google AI Studio \u7533\u8bf7 Gemini API \u5bc6\u94a5\uff0c\u5728\u63d2\u4ef6\u4e2d\u4fdd\u5b58\u540e\u5373\u53ef\u4f7f\u7528\u3002   \u7533\u8bf7\u6559\u7a0b\uff1a\u6253\u5f00 https://aistudio.google.com/apikey \uff0c\u7528 Google \u8d26\u53f7\u767b\u5f55\u540e\u70b9\u51fb\u300cCreate API key\u300d\uff0c\u9009\u62e9\u6216\u65b0\u5efa\u9879\u76ee\u540e\u5373\u53ef\u751f\u6210\u5bc6\u94a5\uff1b\u5c06\u5bc6\u94a5\u590d\u5236\u5230\u63d2\u4ef6\u300cAPI key\u300d\u8f93\u5165\u6846\u5e76\u70b9\u51fb\u300c\u4fdd\u5b58\u300d\u3002</li> <li>\u5bc6\u94a5\u4ec5\u4fdd\u5b58\u5728\u672c\u673a\u6d4f\u89c8\u5668\u4e2d\uff0c\u4e0d\u4f1a\u4e0a\u4f20\u5230 Pin\u597d\u56fe \u6216\u5176\u5b83\u670d\u52a1\u5668\uff1b\u56fe\u7247\u7ecf\u538b\u7f29\u540e\u4ec5\u53d1\u9001\u81f3 Google API \u7528\u4e8e\u8bc6\u56fe\u3002</li> </ul>"},{"location":"usage/#_3","title":"\u4e09\u3001\u57fa\u672c\u6d41\u7a0b","text":"<ol> <li>\u6253\u5f00\u63d2\u4ef6\uff08\u5f39\u7a97\u6216\u4fa7\u8fb9\u680f\uff09\u3002</li> <li>\u4e0a\u4f20 1\uff5e5 \u5f20\u53c2\u8003\u56fe  </li> <li>\u672a\u9009\u56fe\u65f6\uff1a\u70b9\u51fb\u4e2d\u592e\u5e26\u300c+\u300d\u7684\u65b9\u6846\uff0c\u5728\u5f39\u7a97\u4e2d\u9009\u62e9\u56fe\u7247\u3002  </li> <li>\u5df2\u9009\u56fe\u540e\uff1a\u9884\u89c8\u4f1a\u53e0\u653e\u663e\u793a\uff1b\u53ef\u70b9\u51fb\u6bcf\u5f20\u5de6\u4e0a\u89d2\u300c\u00d7\u300d\u5220\u9664\u5355\u5f20\uff1b\u672a\u6ee1 5 \u5f20\u65f6\u4ecd\u53ef\u70b9\u300c+\u300d\u7ee7\u7eed\u6dfb\u52a0\u3002  </li> <li>\u652f\u6301\u62d6\u62fd\uff1a\u5c06\u672c\u5730\u6216\u7f51\u9875\u4e0a\u7684\u56fe\u7247\u62d6\u5165\u4e0a\u4f20\u533a\u5373\u53ef\u6dfb\u52a0\u3002  </li> <li>\u652f\u6301\u7c98\u8d34\uff1a\u9f20\u6807\u5728\u4e0a\u4f20\u533a\u65f6\u6309 Ctrl+V / Cmd+V \u7c98\u8d34\u526a\u8d34\u677f\u4e2d\u7684\u56fe\u7247\u3002</li> <li>\uff08\u53ef\u9009\uff09\u586b\u5199\u300c\u641c\u7d22\u8303\u56f4\u63d0\u793a\u300d  </li> <li>\u5982\uff1a\u6c7d\u8f66\u3001logo\u3001\u914d\u8272\u3001\u6c1b\u56f4\u3001\u6241\u5e73\u98ce \u7b49\uff0c\u5e2e\u52a9 AI \u7f29\u5c0f\u641c\u7d22\u8303\u56f4\uff0c\u7ed3\u679c\u66f4\u8d34\u9898\u3002</li> <li>\u70b9\u51fb\u300c\u4e0a\u4f20\u56fe\u7247\uff0c\u5728 Pinterest \u641c\u76f8\u4f3c\u56fe\u300d  </li> <li>\u63d2\u4ef6\u4f1a\u538b\u7f29\u56fe\u7247\u3001\u8c03\u7528 Gemini \u89e3\u6790\u5e76\u751f\u6210\u5173\u952e\u8bcd\uff0c\u968f\u540e\u5728 Pinterest \u641c\u7d22\u5e76\u8df3\u8f6c\u7ed3\u679c\u9875\u3002</li> </ol>"},{"location":"usage/#_4","title":"\u56db\u3001\u7ed3\u679c\u9875\u4f7f\u7528","text":"<ul> <li>\u9996\u6b21\u70b9\u51fb\u540e\u4f1a\u5728\u5f53\u524d\u6807\u7b7e\u9875\u6253\u5f00 Pinterest \u641c\u7d22\u7ed3\u679c\uff1b\u5efa\u8bae\u5728 Pinterest \u7ad9\u70b9\u4e0b\u4f7f\u7528\u4fa7\u8fb9\u680f\uff0c\u4f53\u9a8c\u66f4\u987a\u3002</li> <li>\u82e5\u5bf9\u5173\u952e\u8bcd\u4e0d\u6ee1\u610f\uff1a\u53ef\u4fee\u6539\u300c\u641c\u7d22\u8303\u56f4\u63d0\u793a\u300d\u540e\u518d\u6b21\u70b9\u51fb\u540c\u4e00\u6309\u94ae\uff0c\u4f1a\u6309\u65b0\u63d0\u793a\u91cd\u65b0\u751f\u6210\u5173\u952e\u8bcd\u5e76\u641c\u7d22\u3002</li> <li>\u6309\u94ae\u4f1a\u53d8\u4e3a\u300c\u6362\u4e00\u4e2a\u5173\u952e\u8bcd\u518d\u8bd5\u8bd5\u300d\uff1a\u53ef\u591a\u6b21\u70b9\u51fb\u4ee5\u5207\u6362\u591a\u7ec4\u5907\u9009\u5173\u952e\u8bcd\uff0c\u65e0\u9700\u91cd\u65b0\u4e0a\u4f20\u56fe\u7247\u3002</li> </ul>"},{"location":"usage/#_5","title":"\u4e94\u3001\u5c0f\u6280\u5de7","text":"<ul> <li>\u53c2\u8003\u56fe\u5c3d\u91cf\u4e3b\u4f53\u6e05\u6670\u3001\u98ce\u683c\u7edf\u4e00\uff0c\u66f4\u6613\u5f97\u5230\u597d\u7528\u5173\u952e\u8bcd\u3002</li> <li>\u63d0\u793a\u8bcd\u5199\u7c7b\u522b\u6216\u98ce\u683c\uff08\u5982\u300c\u5ba4\u5185\u8bbe\u8ba1\u300d\u300c\u6c34\u5f69\u300d\uff09\u6bd4\u5199\u8fc7\u957f\u53e5\u5b50\u66f4\u7a33\u5b9a\u3002</li> <li>\u4fa7\u8fb9\u680f\u5e38\u9a7b\u5728 Pinterest \u9875\u9762\uff0c\u8fb9\u770b\u7ed3\u679c\u8fb9\u6362\u56fe\u3001\u6362\u63d0\u793a\u8bcd\u6700\u65b9\u4fbf\u3002</li> <li>\u4fa7\u8fb9\u680f\u5de6\u4e0a\u89d2\u300c\u5728\u5f39\u7a97\u4e2d\u6253\u5f00\u300d\u53ef\u5728\u65b0\u7a97\u53e3\u4e2d\u6253\u5f00\u63d2\u4ef6\u754c\u9762\u3002</li> <li>\u9ad8\u7ea7\u9009\u9879\u4e2d\u53ef\u70b9\u51fb\u300c\u68c0\u67e5\u66f4\u65b0\u300d\u4ece GitHub \u68c0\u67e5\u65b0\u7248\u672c\uff0c\u6709\u66f4\u65b0\u65f6\u53ef\u4e00\u952e\u4e0b\u8f7d\u53d1\u5e03\u5305\u3002</li> </ul>"},{"location":"usage/#_6","title":"\u516d\u3001\u5e38\u89c1\u95ee\u9898","text":"<ul> <li>\u82e5 Pinterest \u9875\u9762\u663e\u793a\u300c\u62b1\u6b49\uff01\u5f53\u524d\u6709\u592a\u591a\u7528\u6237\u4f7f\u7528\u6211\u4eec\u7684\u641c\u7d22\u529f\u80fd\u3002\u8bf7\u7a0d\u540e\u91cd\u8bd5\u3002\u300d\uff1a\u8fd9\u662f Pinterest \u5b98\u65b9\u7684\u9650\u6d41\u6216\u7e41\u5fd9\u63d0\u793a\uff0c\u5e76\u975e\u63d2\u4ef6\u6545\u969c\u3002\u8bf7\u7a0d\u7b49 1\uff5e2 \u5206\u949f\u540e\u518d\u5237\u65b0\u9875\u9762\u91cd\u8bd5\uff0c\u6216\u5c1d\u8bd5\u5207\u6362 VPN \u7ebf\u8def\uff1b\u907f\u514d\u5728\u77ed\u65f6\u95f4\u5185\u8fde\u7eed\u591a\u6b21\u70b9\u51fb\u300c\u6362\u4e00\u4e2a\u5173\u952e\u8bcd\u518d\u8bd5\u8bd5\u300d\u3002\u63d2\u4ef6\u4f1a\u5728\u68c0\u6d4b\u5230\u8be5\u63d0\u793a\u65f6\u5728\u9875\u9762\u9876\u90e8\u663e\u793a\u7b80\u77ed\u8bf4\u660e\u4e0e\u300c\u5237\u65b0\u300d\u6309\u94ae\u3002</li> </ul>"}]}